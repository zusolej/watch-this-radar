---
type Variant = "info" | "warning" | "error";

interface Props {
  variant?: Variant;
}

const { variant = "info" } = Astro.props;
---

<div class:list={["banner", `banner--${variant}`]} role={variant === "error" ? "alert" : "status"}>
  <slot />
</div>

<style>
  .banner {
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    text-align: center;
    border-bottom: 1px solid;
  }
  .banner :global(a) {
    color: inherit;
    text-decoration: underline;
    font-weight: 600;
  }
  .banner--info {
    background: #dbeafe;
    color: #1e3a8a;
    border-color: #3b82f6;
  }
  .banner--warning {
    background: #fef3c7;
    color: #78350f;
    border-color: #f59e0b;
  }
  .banner--error {
    background: #fee2e2;
    color: #7f1d1d;
    border-color: #dc2626;
  }
</style>
